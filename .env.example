# Required
TELEGRAM_BOT_TOKEN=

# Subscription gate
REQUIRED_CHANNEL=@privatekey_ai
SUBSCRIPTION_CACHE_TTL_MIN=5

# Optional / defaults
DATABASE_PATH=./data/bot.db
HISTORY_MESSAGES=20
DEFAULT_MODEL=gpt-5-nano
LOG_LEVEL=info

# HTTPS URL of the auth-helper Mini App (web/login.html). Recommended:
# enable GitHub Pages on this repo (Settings → Pages → Source: GitHub
# Actions). The included .github/workflows/pages.yml will publish web/
# automatically and the URL will look like:
#   https://<your-username>.github.io/FreeAI/login.html
# If unset, the bot falls back to a plain "paste your token here" flow.
LOGIN_HELPER_URL=

# Optional: HTTP(S) proxy for outbound requests (Telegram + Puter API).
# Format: http://user:pass@host:port — Node's native fetch is forced
# through this via undici's ProxyAgent.
# HTTPS_PROXY=
# HTTP_PROXY=
# NO_PROXY=localhost,127.0.0.1
